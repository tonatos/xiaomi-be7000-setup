http:
  address: "0.0.0.0:{{ adguardhome_admin_port }}"
{% if adguardhome_http_proxy %}
http_proxy: {{ adguardhome_http_proxy | tojson }}
{% endif %}

dns:
  bind_hosts:
{% for host in adguardhome_bind_hosts %}
    - {{ host | tojson }}
{% endfor %}
  port: {{ adguardhome_dns_port }}
  use_private_ptr_resolvers: false
  upstream_dns:
{% for upstream in adguardhome_upstream_dns %}
    - {{ upstream | tojson }}
{% endfor %}
{% if adguardhome_bootstrap_dns %}
  bootstrap_dns:
{% for bootstrap in adguardhome_bootstrap_dns %}
    - {{ bootstrap | tojson }}
{% endfor %}
{% endif %}
{% if adguardhome_fallback_dns %}
  fallback_dns:
{% for fallback in adguardhome_fallback_dns %}
    - {{ fallback | tojson }}
{% endfor %}
{% endif %}
{% if adguardhome_allowed_clients %}
  allowed_clients:
{% for client in adguardhome_allowed_clients %}
    - {{ client | tojson }}
{% endfor %}
{% endif %}
{% if adguardhome_disallowed_clients %}
  disallowed_clients:
{% for client in adguardhome_disallowed_clients %}
    - {{ client | tojson }}
{% endfor %}
{% endif %}

filtering:
  protection_enabled: true
  filtering_enabled: true
  filters_update_interval: {{ adguardhome_filters_update_interval }}

filters:
  - enabled: true
    url: "https://adguardteam.github.io/HostlistsRegistry/assets/filter_1.txt"
    name: "AdGuard DNS filter"
    id: 1
  - enabled: true
    url: "https://raw.githubusercontent.com/AdguardTeam/FiltersRegistry/master/filters/filter_1_Russian/filter.txt"
    name: "AdGuard Russian filter"
    id: 101
  - enabled: false
    url: "https://adguardteam.github.io/HostlistsRegistry/assets/filter_2.txt"
    name: "AdAway Default Blocklist"
    id: 2
