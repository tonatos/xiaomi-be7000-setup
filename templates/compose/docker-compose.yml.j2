services:
{% if services.xray_server.enabled | default(true) %}
  {{ services.xray_server.container_name }}:
    image: {{ services.xray_server.image | tojson }}
    container_name: {{ services.xray_server.container_name | tojson }}
    restart: unless-stopped
    network_mode: host
    volumes:
      - ./configs/xray:/etc/xray:ro
    command: ["run", "-c", "/etc/xray/config.json"]
{% endif %}
{% if services.mihomo.enabled | default(true) %}

  {{ services.mihomo.container_name }}:
    image: {{ services.mihomo.image | tojson }}
    container_name: {{ services.mihomo.container_name | tojson }}
    restart: unless-stopped
    network_mode: host
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun
    volumes:
{% if services.mihomo.volume is defined %}
      - "{{ services.mihomo.volume }}"
{% else %}
      # Runtime mihomo (GeoSite/GeoIP и кэш) держим вне stack.
      - "{{ services.mihomo.runtime_volume | default('../mihomo-runtime:/root/.config/mihomo') }}"
      - "{{ services.mihomo.settings_volume | default('./configs/mihomo-config/config.yaml:/root/.config/mihomo/config.yaml:ro') }}"
{% endif %}
{% endif %}
{% if services.v2raya.enabled | default(false) %}

  {{ services.v2raya.container_name }}:
    image: {{ services.v2raya.image | tojson }}
    container_name: {{ services.v2raya.container_name | tojson }}
    restart: unless-stopped
    network_mode: host
    privileged: true
    environment:
      - V2RAYA_LOG_FILE=/tmp/v2raya.log
      - V2RAYA_V2RAY_BIN=/usr/local/bin/v2ray
      - V2RAYA_NFTABLES_SUPPORT=off
      - IPTABLES_MODE=legacy
    volumes:
      - /lib/modules:/lib/modules:ro
      - /etc/resolv.conf:/etc/resolv.conf
{% if services.v2raya.volume is defined %}
      - "{{ services.v2raya.volume }}"
{% else %}
      - "{{ services.v2raya.runtime_volume | default('../v2raya-runtime:/etc/v2raya') }}"
{% endif %}
{% endif %}
{% set ts = services.torrserver | default({}) %}
{% if ts.enabled | default(true) %}

  {{ ts.container_name | default("torrserver") }}:
    image: {{ ts.image | default("ghcr.io/yourok/torrserver:latest") | tojson }}
    container_name: {{ ts.container_name | default("torrserver") | tojson }}
    restart: unless-stopped
    network_mode: host
    environment:
      - TS_DONTKILL={{ ts.dontkill | default(0) }}
      - TS_PORT={{ ts.port | default(8090) }}
      # ghcr.io/yourok/torrserver uses TS_CONF_PATH/TS_LOG_PATH/TS_TORR_DIR.
      - TS_CONF_PATH={{ ts.path | default("/opt/torrserver/config") }}
      - TS_LOG_PATH={{ ts.log_path | default((ts.log_path_dir | default("/opt/torrserver/log")) ~ "/" ~ (ts.log_file | default("torrserver.log"))) }}
      - TS_TORR_DIR={{ ts.torrents_dir | default("/opt/torrserver/torrents") }}
{% if ts.environment is defined %}
{{ ts.environment | toyaml | indent(6, first=True) }}
{% endif %}
    volumes:
{% if ts.volume is defined %}
      - "{{ ts.volume }}"
{% else %}
      - "{{ ts.runtime_volume | default('../torrserver-runtime:/opt/torrserver') }}"
      - "{{ ts.settings_volume | default('./configs/torrserver/config/settings.json:/opt/torrserver/config/settings.json:ro') }}"
{% endif %}
{% if ts.volumes is defined %}
{{ ts.volumes | toyaml | indent(6, first=True) }}
{% endif %}
{% endif %}
{% set metacubexd = services.metacubexd | default({}) %}
{% if metacubexd.enabled | default(true) %}

  {{ metacubexd.container_name | default("metacubexd") }}:
    image: {{ metacubexd.image | default("gzxhwq/metacubexd:latest") | tojson }}
    container_name: {{ metacubexd.container_name | default("metacubexd") | tojson }}
    restart: unless-stopped
    ports:
      - "{{ services_metacubexd_port }}:80"
    environment:
      - DEFAULT_BACKEND_URL={{ services_metacubexd_default_backend_url }}
{% endif %}
{% set custom = services.custom | default({}) %}
{% for service_name, service_cfg in custom.items() %}

  {{ service_name }}:
{{ service_cfg | toyaml | indent(4, first=True) }}
{% endfor %}
{% set agh = services.adguardhome | default({}) %}
{% if agh.enabled | default(true) %}

  {{ agh.container_name | default("adguardhome") }}:
    image: {{ agh.image | default("docker.io/adguard/adguardhome:latest") | tojson }}
    container_name: {{ agh.container_name | default("adguardhome") | tojson }}
    restart: unless-stopped
    network_mode: {{ agh.network_mode | default("host") | tojson }}
    volumes:
      - "{{ agh.work_dir | default('../adguardhome-runtime/work') }}:/opt/adguardhome/work"
      - "{{ agh.conf_dir | default('./configs/adguardhome/conf') }}:/opt/adguardhome/conf"
{% endif %}
