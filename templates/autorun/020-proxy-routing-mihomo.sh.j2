#!/bin/sh
# Автозапуск mihomo и применение lan-routing. Generated by xiaomi-be7000-setup.

if [ "{{ 1 if services_mihomo_enabled else 0 }}" != "1" ]; then
    logger -t mihomo-autostart "mihomo отключён в services — пропускаю"
    exit 0
fi

_mihomo_autostart() {
    TAG="mihomo-autostart"
    DOCK="{{ docker_bin }}"
    ROUTING_DIR="{{ stack_path }}/routing"
    ROUTING_SCRIPT="$ROUTING_DIR/lan-routing.sh"
    REDIR_PORT={{ services_mihomo_redir_port }}

    MAX_DOCKER_WAIT=300
    MAX_MIHOMO_WAIT=60

    _fail_open_restore_internet() {
        if [ -x "$ROUTING_SCRIPT" ]; then
            logger -t $TAG "fail-open: снимаю project-managed правила (lan-routing stop)"
            sh "$ROUTING_SCRIPT" stop 2>&1 | logger -t $TAG
        fi
    }

    logger -t $TAG "Фоновый автозапуск mihomo начат"

    waited=0
    while [ $waited -lt $MAX_DOCKER_WAIT ]; do
        if "$DOCK" info >/dev/null 2>&1; then
            break
        fi
        sleep 5
        waited=$((waited + 5))
    done

    if ! "$DOCK" info >/dev/null 2>&1; then
        logger -t $TAG "Docker daemon не поднялся за ${MAX_DOCKER_WAIT}с — пропускаю"
        _fail_open_restore_internet
        return 1
    fi
    logger -t $TAG "Docker daemon готов (ожидание: ${waited}с)"

    if "$DOCK" ps --format '{% raw %}{{.Names}}{% endraw %}' 2>/dev/null | grep -qw {{ services_mihomo_container_name }}; then
        logger -t $TAG "Контейнер {{ services_mihomo_container_name }} уже запущен"
    else
        logger -t $TAG "Запускаю контейнер {{ services_mihomo_container_name }}..."
        START_OUT=$("$DOCK" start {{ services_mihomo_container_name }} 2>&1)
        START_RC=$?
        [ -n "$START_OUT" ] && printf '%s\n' "$START_OUT" | logger -t $TAG
        if [ $START_RC -ne 0 ]; then
            logger -t $TAG "Не удалось запустить {{ services_mihomo_container_name }} — пропускаю маршрутизацию"
            _fail_open_restore_internet
            return 1
        fi
    fi

    waited=0
    while [ $waited -lt $MAX_MIHOMO_WAIT ]; do
        if netstat -tlnp 2>/dev/null | grep -q ":${REDIR_PORT}.*{{ services_mihomo_container_name }}"; then
            break
        fi
        sleep 3
        waited=$((waited + 3))
    done

    if ! netstat -tlnp 2>/dev/null | grep -q ":${REDIR_PORT}.*{{ services_mihomo_container_name }}"; then
        logger -t $TAG "{{ services_mihomo_container_name }} не открыл порт $REDIR_PORT за ${MAX_MIHOMO_WAIT}с — пропускаю"
        _fail_open_restore_internet
        return 1
    fi
    logger -t $TAG "mihomo redir-port $REDIR_PORT готов"

    if [ ! -x "$ROUTING_SCRIPT" ]; then
        logger -t $TAG "Нет исполняемого $ROUTING_SCRIPT — пропускаю iptables"
        return 0
    fi

    logger -t $TAG "Применяю правила маршрутизации..."
    sh "$ROUTING_SCRIPT" start 2>&1 | logger -t $TAG
    logger -t $TAG "Автозапуск mihomo завершён"
}

_mihomo_autostart </dev/null >/dev/null 2>&1 &
