#!/bin/sh
# Фоновый автозапуск v2raya и применение дополнительных правил маршрутизации. Generated by xiaomi-be7000-setup.

_v2raya_autostart() {
    TAG="v2raya-autostart"
    DOCK="{{ docker_bin }}"
    ROUTING_DIR="{{ stack_path }}/routing"
    ROUTING_SCRIPT="$ROUTING_DIR/lan-routing.sh"
    PORT={{ services_v2raya_port }}
    REDIR_PORT={{ services_v2raya_redir_port }}
    TRANSPARENT_MODE="{{ v2raya.transparent_mode | default('tun') }}"
    APPLY_IPT={% if routing.apply_iptables | default(false) %}1{% else %}0{% endif %}

    MAX_DOCKER_WAIT=300
    MAX_V2RAYA_WAIT=60

    logger -t $TAG "Фоновый автозапуск v2raya начат"

    waited=0
    while [ $waited -lt $MAX_DOCKER_WAIT ]; do
        if "$DOCK" info >/dev/null 2>&1; then
            break
        fi
        sleep 5
        waited=$((waited + 5))
    done

    if ! "$DOCK" info >/dev/null 2>&1; then
        logger -t $TAG "Docker daemon не поднялся за ${MAX_DOCKER_WAIT}с — пропускаю"
        return 1
    fi
    logger -t $TAG "Docker daemon готов (ожидание: ${waited}с)"

    if "$DOCK" ps --format '{% raw %}{{.Names}}{% endraw %}' 2>/dev/null | grep -qw {{ services_v2raya_container_name }}; then
        logger -t $TAG "Контейнер {{ services_v2raya_container_name }} уже запущен"
    else
        logger -t $TAG "Запускаю контейнер {{ services_v2raya_container_name }}..."
        "$DOCK" start {{ services_v2raya_container_name }} 2>&1 | logger -t $TAG
        if [ $? -ne 0 ]; then
            logger -t $TAG "Не удалось запустить {{ services_v2raya_container_name }} — пропускаю маршрутизацию"
            return 1
        fi
    fi

    waited=0
    while [ $waited -lt $MAX_V2RAYA_WAIT ]; do
        if netstat -tlnp 2>/dev/null | grep -q ":${PORT}.*{{ services_v2raya_container_name }}"; then
            break
        fi
        sleep 3
        waited=$((waited + 3))
    done

    if ! netstat -tlnp 2>/dev/null | grep -q ":${PORT}.*{{ services_v2raya_container_name }}"; then
        logger -t $TAG "{{ services_v2raya_container_name }} не открыл порт $PORT за ${MAX_V2RAYA_WAIT}с — пропускаю"
        return 1
    fi
    logger -t $TAG "v2raya port $PORT готов"

    if [ "$APPLY_IPT" = "1" ] && [ "$TRANSPARENT_MODE" = "redirect" ]; then
        waited=0
        while [ $waited -lt $MAX_V2RAYA_WAIT ]; do
            if netstat -tlnp 2>/dev/null | grep -q ":${REDIR_PORT}.*{{ services_v2raya_container_name }}"; then
                break
            fi
            sleep 3
            waited=$((waited + 3))
        done
        if ! netstat -tlnp 2>/dev/null | grep -q ":${REDIR_PORT}.*{{ services_v2raya_container_name }}"; then
            logger -t $TAG "Ожидался transparent redir-порт $REDIR_PORT (включите в v2rayA прозрачный прокси Redirect); пропускаю lan-routing"
            return 1
        fi
        logger -t $TAG "v2raya transparent redir-port $REDIR_PORT готов"
    elif [ "$APPLY_IPT" = "1" ] && [ "$TRANSPARENT_MODE" = "tun" ]; then
        logger -t $TAG "v2raya transparent_mode=tun: ожидание redir-порта пропущено, iptables REDIRECT не требуется"
    fi

    if [ ! -x "$ROUTING_SCRIPT" ]; then
        logger -t $TAG "Нет исполняемого $ROUTING_SCRIPT — пропускаю iptables"
        return 0
    fi

    logger -t $TAG "Применяю дополнительные правила маршрутизации..."
    sh "$ROUTING_SCRIPT" start 2>&1 | logger -t $TAG
    logger -t $TAG "Автозапуск v2raya завершён"
}

_v2raya_autostart </dev/null >/dev/null 2>&1 &
