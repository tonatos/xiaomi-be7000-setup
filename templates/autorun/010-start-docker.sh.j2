#!/bin/sh
# Автозапуск Docker (mi_docker). Generated by xiaomi-be7000-setup.

_start_docker() {
    TAG="docker-autostart"
    USB_MOUNT="/mnt/usb"
    DOCK="{{ docker_bin }}"
    MAX_WAIT=300
    waited=0

    _swap_total_kb() {
        awk '/^SwapTotal:/ {print $2}' /proc/meminfo 2>/dev/null
    }

    _first_usb_root() {
        ls -d ${USB_MOUNT}* 2>/dev/null | head -1
    }

    _ensure_swap() {
        SWAP_KB="$(_swap_total_kb)"
        [ -n "$SWAP_KB" ] || SWAP_KB=0
        if [ "$SWAP_KB" -gt 0 ]; then
            logger -t $TAG "Swap уже активен (${SWAP_KB} kB)"
            return 0
        fi

        USB_ROOT="$(_first_usb_root)"
        if [ -z "$USB_ROOT" ] || [ ! -d "$USB_ROOT" ]; then
            logger -t $TAG "USB для swap пока не найден"
            return 1
        fi

        SWAPFILE="${USB_ROOT}/.swapfile"
        if [ ! -f "$SWAPFILE" ]; then
            logger -t $TAG "Создаю swapfile 256MB: $SWAPFILE"
            if ! dd if=/dev/zero of="$SWAPFILE" bs=1M count=256 2>&1 | logger -t $TAG; then
                logger -t $TAG "Не удалось создать swapfile"
                return 1
            fi
            chmod 600 "$SWAPFILE" 2>/dev/null || true
            if ! mkswap "$SWAPFILE" 2>&1 | logger -t $TAG; then
                logger -t $TAG "mkswap завершился ошибкой"
                return 1
            fi
        fi

        if swapon "$SWAPFILE" 2>&1 | logger -t $TAG; then
            SWAP_KB="$(_swap_total_kb)"
            [ -n "$SWAP_KB" ] || SWAP_KB=0
            logger -t $TAG "Swap активирован (${SWAP_KB} kB)"
            return 0
        fi

        logger -t $TAG "swapon не удался для $SWAPFILE"
        return 1
    }

    while [ $waited -lt $MAX_WAIT ]; do
        if ls ${USB_MOUNT}*/mi_docker >/dev/null 2>&1; then
            break
        fi
        sleep 5
        waited=$((waited + 5))
    done

    if ! ls ${USB_MOUNT}*/mi_docker >/dev/null 2>&1; then
        logger -t $TAG "USB с mi_docker не найден за ${MAX_WAIT}с — пропускаю"
        return 1
    fi
    logger -t $TAG "USB смонтирован (ожидание: ${waited}с)"

    if ! _ensure_swap; then
        logger -t $TAG "WARN: swap не активирован, возможны OOM и перезапуски контейнеров"
    fi

    if "$DOCK" info >/dev/null 2>&1; then
        logger -t $TAG "Docker daemon уже запущен"
        return 0
    fi

    logger -t $TAG "Запускаю mi_docker..."
    /etc/init.d/mi_docker start 2>&1 | logger -t $TAG

    sleep 5
    if "$DOCK" info >/dev/null 2>&1; then
        logger -t $TAG "Docker daemon запущен"
    else
        logger -t $TAG "Docker daemon не ответил, пробую ещё раз..."
        /etc/init.d/mi_docker start 2>&1 | logger -t $TAG
    fi
}

_start_docker </dev/null >/dev/null 2>&1 &
