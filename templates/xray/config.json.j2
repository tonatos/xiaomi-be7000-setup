{
  "log": {
    "loglevel": "{{ xray.log_level | default('warning') }}"
  },
  "inbounds": [
    {
      "tag": "{{ xray.inbound.tag }}",
      "listen": "{{ xray.inbound.listen }}",
      "port": {{ xray.inbound.port }},
      "protocol": "{{ xray.inbound.protocol | default('vless') }}",
      "settings": {
        "clients": [
{% for client in xray.clients %}
          {
            "id": {{ client.id | tojson }},
            "flow": {{ client.flow | default('xtls-rprx-vision') | tojson }}
          }{{ "," if not loop.last }}
{% endfor %}
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "raw",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "target": "{{ xray.reality.dest }}",
          "xver": {{ xray.reality.xver | default(0) }},
          "serverNames": {{ xray.reality.server_names | tojson }},
          "privateKey": {{ xray.reality.private_key | tojson }},
          "shortIds": {{ xray.reality.short_ids | tojson }},
          "fingerprint": "{{ xray.reality.fingerprint | default('chrome') }}"
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"]
      }
    }
  ],
  "outbounds": [
    {
      "tag": "to-proxy",
      "protocol": "socks",
      "settings": {
        "servers": [
          {
            "address": "{{ xray.routing.socks_upstream_host }}",
            "port": {{ xray.routing.socks_upstream_port }}
          }
        ]
      }
    },
    {
      "tag": "blocked",
      "protocol": "blackhole"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "inboundTag": ["{{ xray.inbound.tag }}"],
        "outboundTag": "to-proxy"
      }
    ]
  }
}
