#!/bin/sh
# Откат iptables-правил LAN (routing). Generated by xiaomi-be7000-setup.
# Использование: sh rollback.sh

ROUTING_DIR="{{ stack_path }}/routing"
ROUTING_SCRIPT="$ROUTING_DIR/lan-routing.sh"

if [ -x "$ROUTING_SCRIPT" ]; then
    sh "$ROUTING_SCRIPT" stop
    logger -t lan-routing-rollback "Правила lan-routing сброшены"
else
    logger -t lan-routing-rollback "Скрипт $ROUTING_SCRIPT не найден или не исполняемый"
    exit 1
fi
