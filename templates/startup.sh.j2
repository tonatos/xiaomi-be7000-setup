#!/bin/sh
# Autorun entry (firewall include). Generated by xiaomi-be7000-setup.

LOCK="/tmp/startup_done.lock"
[ -e "$LOCK" ] && exit 0

BASEDIR="{{ startup_base }}/{{ startup_autoruns }}"

logger -t startup "Running autoruns from $BASEDIR"

for f in "$BASEDIR"/*; do
    [ -x "$f" ] || continue
    logger -t startup "Spawning $f in background"
    sh "$f" </dev/null >/dev/null 2>&1 &
done

touch "$LOCK"
