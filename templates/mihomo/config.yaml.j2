# Generated by xiaomi-be7000-setup
mixed-port: {{ services.mihomo.mixed_port | default(7890) }}
redir-port: {{ services.mihomo.redir_port | default(7891) }}
allow-lan: true
mode: rule
log-level: info

proxies:
  - name: {{ mihomo_proxy.name | default('upstream') }}
    type: vless
    server: {{ mihomo_proxy.server | tojson }}
    port: {{ mihomo_proxy.port }}
    uuid: {{ mihomo_proxy.uuid | tojson }}
    network: tcp
    tls: true
    udp: true
    flow: {{ mihomo_proxy.flow | default('xtls-rprx-vision') | tojson }}
    servername: {{ mihomo_proxy.sni | tojson }}
    client-fingerprint: {{ mihomo_proxy.fingerprint | default('chrome') | tojson }}
    reality-opts:
      public-key: {{ mihomo_proxy.public_key | tojson }}
      short-id: {{ mihomo_proxy.short_id | tojson }}

proxy-groups:
  - name: default
    type: select
    proxies:
      - {{ mihomo_proxy.name | default('upstream') }}

rules:
  - MATCH,default
