#!/bin/sh
# Правила прозрачной маршрутизации mihomo.
# Включение: routing.apply_iptables в router.yaml
#
# ВАЖНО — исключённые IP (routing.excluded_ips):
#   Устройства с прямым NAT (Xbox, PS, Nintendo и др.) не должны проходить
#   через прозрачный прокси. Mihomo завершает TCP-соединение и открывает новое
#   от имени роутера, из-за чего Xbox видит чужой порт и не может определить
#   NAT-тип. Добавьте IP таких устройств в routing.excluded_ips (см. router.yaml).

CHAIN="MIHOMO_{{ services.mihomo.container_name | default('mihomo') | upper | replace('-', '_') }}"

_start() {
{% if routing.apply_iptables | default(false) %}
    iptables -t nat -N "$CHAIN" 2>/dev/null || iptables -t nat -F "$CHAIN"
    # Устройства с прямым NAT: обходят прокси полностью
{% for ip in routing.excluded_ips | default([]) %}
    iptables -t nat -A "$CHAIN" -s {{ ip }} -j RETURN
{% endfor %}
    # Частные и служебные диапазоны назначения: не проксируем
    iptables -t nat -A "$CHAIN" -d 0.0.0.0/8 -j RETURN
    iptables -t nat -A "$CHAIN" -d 10.0.0.0/8 -j RETURN
    iptables -t nat -A "$CHAIN" -d 127.0.0.0/8 -j RETURN
    iptables -t nat -A "$CHAIN" -d 169.254.0.0/16 -j RETURN
    iptables -t nat -A "$CHAIN" -d 172.16.0.0/12 -j RETURN
    iptables -t nat -A "$CHAIN" -d 192.168.0.0/16 -j RETURN
    iptables -t nat -A "$CHAIN" -d 224.0.0.0/4 -j RETURN
    iptables -t nat -A "$CHAIN" -d 240.0.0.0/4 -j RETURN
    iptables -t nat -A "$CHAIN" -p tcp -j REDIRECT --to-ports {{ services.mihomo.redir_port }}
    iptables -t nat -C PREROUTING -s {{ routing.lan_cidr }} -p tcp -j "$CHAIN" 2>/dev/null || \
      iptables -t nat -A PREROUTING -s {{ routing.lan_cidr }} -p tcp -j "$CHAIN"
    logger -t mihomo-routing "iptables nat redirect -> {{ services.mihomo.redir_port }} for {{ routing.lan_cidr }}"
{% else %}
    logger -t mihomo-routing "apply_iptables=false — правила не применялись (настройте routing в router.yaml)"
{% endif %}
{% if routing.block_quic | default(false) %}
    # Блокируем QUIC (HTTP/3, UDP/443) из LAN: браузеры деградируют на TCP/443 через прокси
    iptables -C FORWARD -s {{ routing.lan_cidr }} -p udp --dport 443 -j DROP 2>/dev/null || \
      iptables -I FORWARD -s {{ routing.lan_cidr }} -p udp --dport 443 -j DROP
    logger -t mihomo-routing "iptables FORWARD DROP UDP/443 (QUIC) for {{ routing.lan_cidr }}"
{% endif %}
}

_stop() {
{% if routing.apply_iptables | default(false) %}
    iptables -t nat -D PREROUTING -s {{ routing.lan_cidr }} -p tcp -j "$CHAIN" 2>/dev/null || true
    iptables -t nat -F "$CHAIN" 2>/dev/null || true
    iptables -t nat -X "$CHAIN" 2>/dev/null || true
{% endif %}
{% if routing.block_quic | default(false) %}
    iptables -D FORWARD -s {{ routing.lan_cidr }} -p udp --dport 443 -j DROP 2>/dev/null || true
{% endif %}
}

case "$1" in
    start) _start ;;
    stop) _stop ;;
    *) echo "usage: $0 start|stop" ;;
esac
